# LLM Providers (get keys from respective consoles)
GEMINI_API_KEY=your-gemini-key-from-aistudio.google.com
CEREBRAS_API_KEY=your-cerebras-key-from-cloud.cerebras.ai
ANTHROPIC_API_KEY=your-anthropic-key-from-console.anthropic.com

# Model routing (3 tiers by task complexity)
MODEL_SIMPLE=cerebras/llama-3.3-70b
MODEL_DEFAULT=gemini/gemini-2.5-flash
MODEL_COMPLEX=anthropic/claude-haiku-4-5-20251001

# LLM Settings
LLM_TEMPERATURE=0.1

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Data
DATA_DIR=./data
MAX_CSV_SIZE_MB=10
